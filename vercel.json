{
  "rewrites": [
    { "source": "/resumen", "destination": "/resumen.html" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/aviso-noche",   "schedule": "50 14 * * *" },
    { "path": "/api/reporte-noche", "schedule": "0 15 * * *"  },
    { "path": "/api/reporte-manana","schedule": "30 18 * * *" },
    { "path": "/api/aviso-dia",     "schedule": "20 3 * * *"  },
    { "path": "/api/reporte-dia",   "schedule": "30 3 * * *"  }
  ]
}
